@model Balkana.Data.Models.Series

@{
    ViewData["Title"] = "Edit Series";
}

@section Styles {
    <link rel="stylesheet" href="~/css/series-details.css" asp-append-version="true" />
}

<div class="series-details-container">
    <div class="series-header series-edit-header">
        <div class="series-title-section">
            <h1 class="series-title">Edit Series</h1>
            <p class="series-edit-lead">Update teams, tournament, and schedule. Use <strong>TBD</strong> when the matchup is not set yet.</p>
        </div>
    </div>

    <form asp-action="Edit" class="series-edit-form">
        <input type="hidden" asp-for="Id" />

        <div class="series-edit-field">
            <label asp-for="Name" class="series-edit-label"></label>
            <input asp-for="Name" class="series-edit-input" />
            <span asp-validation-for="Name" class="series-edit-validation"></span>
        </div>

        <div class="series-edit-field">
            <label asp-for="TeamAId" class="series-edit-label">Team A</label>
            <select asp-for="TeamAId" class="series-edit-input series-edit-select" asp-items="ViewBag.TeamAId"></select>
            <span asp-validation-for="TeamAId" class="series-edit-validation"></span>
        </div>

        <div class="series-edit-field">
            <label asp-for="TeamBId" class="series-edit-label">Team B</label>
            <select asp-for="TeamBId" class="series-edit-input series-edit-select" asp-items="ViewBag.TeamBId"></select>
            <span asp-validation-for="TeamBId" class="series-edit-validation"></span>
        </div>

        <div class="series-edit-field">
            <label asp-for="TournamentId" class="series-edit-label">Tournament</label>
            <select asp-for="TournamentId" class="series-edit-input series-edit-select" asp-items="ViewBag.TournamentId"></select>
            <span asp-validation-for="TournamentId" class="series-edit-validation"></span>
        </div>

        <div class="series-edit-field">
            <label asp-for="DatePlayed" class="series-edit-label"></label>
            <input asp-for="DatePlayed" class="series-edit-input" type="date" />
            <span asp-validation-for="DatePlayed" class="series-edit-validation"></span>
        </div>

        <div class="action-buttons series-edit-actions">
            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>
