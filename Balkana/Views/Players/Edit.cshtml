@model PlayerFormModel
@{
    ViewData["Title"] = "Edit Player";
    ViewBag.FormAction = "Edit";
    ViewBag.FormHeading = "Edit player";
}

@section Styles {
    <style>
        .player-form-card {
            background: linear-gradient(135deg, rgba(255, 255, 255, 0.06) 0%, rgba(255, 255, 255, 0.02) 100%) !important;
            backdrop-filter: blur(12px);
        }
        .player-form-card .form-control:focus, .player-form-card .form-select:focus {
            border-color: rgba(255, 255, 255, 0.35);
            box-shadow: 0 0 0 0.2rem rgba(255, 255, 255, 0.15);
            color: #fff;
            background-color: #1a1a1a;
        }
    </style>
}

<div class="container py-5">
    <partial name="_PlayersFormPartial" model="Model" />
</div>
