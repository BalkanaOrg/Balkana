@model PlayerFormModel
@{
    var formAction = ViewBag.FormAction as string ?? "Add";
    var formHeading = ViewBag.FormHeading as string ?? (Model.Id == 0 ? "Add a player" : "Edit player");
}

<div class="row">
    <div class="col-lg-6 offset-lg-3 col-sm-12 col-xl-6">
        <div class="player-form-card card shadow-sm border border-secondary">
            <div class="card-body p-4">
                <h2 class="text-center text-white mb-4">@formHeading</h2>
                <form asp-controller="Players" asp-action="@formAction"
                      asp-route-id="@(Model.Id > 0 ? (int?)Model.Id : null)"
                      enctype="multipart/form-data"
                      method="post">
                    @if (Model.Id > 0)
                    {
                        <input type="hidden" asp-for="Id" />
                    }

                    <div class="mb-3">
                        <label asp-for="Nickname" class="form-label text-white-50"></label>
                        <input asp-for="Nickname" class="form-control bg-dark text-white border-secondary" placeholder="e.g. Meally" autocomplete="off" />
                        <span asp-validation-for="Nickname" class="small text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="FirstName" class="form-label text-white-50"></label>
                        <input asp-for="FirstName" class="form-control bg-dark text-white border-secondary" placeholder="e.g. Kris" autocomplete="off" />
                        <span asp-validation-for="FirstName" class="small text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="LastName" class="form-label text-white-50"></label>
                        <input asp-for="LastName" class="form-control bg-dark text-white border-secondary" placeholder="e.g. Ivanov" autocomplete="off" />
                        <span asp-validation-for="LastName" class="small text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="NationalityId" class="form-label text-white-50"></label>
                        <select asp-for="NationalityId" class="form-select bg-dark text-white border-secondary">
                            @foreach (var nationality in Model.Nationalities)
                            {
                                <option value="@nationality.Id">@nationality.Name</option>
                            }
                        </select>
                        <span asp-validation-for="NationalityId" class="small text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="PictureFile" class="form-label text-white-50"></label>
                        <input asp-for="PictureFile" type="file" class="form-control bg-dark text-white border-secondary" accept="image/*" />
                        <span asp-validation-for="PictureFile" class="small text-danger"></span>
                        <div class="form-text text-white-50">Optional. Uploading a new image will become the player’s latest profile picture.</div>
                    </div>

                    <button class="btn btn-primary float-end" type="submit">Save</button>
                </form>
            </div>
        </div>
    </div>
</div>
