@model Balkana.Models.Community.CommunityIndexViewModel

<div class="community-page">
    <div class="community-header">
        <div>
            <h1 class="community-title">Community</h1>
            <p class="community-subtitle">
                Create teams, invite players, and get approved for Balkana tournaments. Moderators verify each roster has the required accounts (FACEIT / Riot).
            </p>
        </div>
        <div class="community-actions">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-action="CreateTeam" class="btn-modern btn-modern-primary">
                    <i class="fi fi-rr-plus"></i>
                    <span>Create team</span>
                </a>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login" class="btn-modern btn-modern-primary">
                    <i class="fi fi-rr-user"></i>
                    <span>Login to create a team</span>
                </a>
            }

            @if (Model.CanModerate)
            {
                <a asp-action="Moderation" class="btn-modern btn-modern-secondary">
                    <i class="fi fi-rr-shield-check"></i>
                    <span>Moderation</span>
                </a>
            }
        </div>
    </div>

    <div class="community-card">
        <div class="community-card-body">
            <form method="get" asp-action="Index" class="community-actions">
                <div class="search-wrapper" style="flex: 1; min-width: 260px;">
                    <i class="fi fi-rr-search search-icon"></i>
                    <input class="search-input-layout" type="text" name="searchTerm" value="@Model.SearchTerm" placeholder="Search users or teams..." />
                </div>
                <button type="submit" class="btn-modern btn-modern-secondary">
                    <i class="fi fi-rr-search"></i>
                    <span>Search</span>
                </button>
            </form>
        </div>
    </div>

    <div style="height: 22px;"></div>

    <div class="community-grid">
        <div class="community-card">
            <div class="community-card-body">
                <div class="community-actions" style="justify-content: space-between;">
                    <h3 style="margin: 0;">Teams</h3>
                    <span class="community-badge">@Model.Teams.Count results</span>
                </div>

                @if (Model.Teams.Count == 0)
                {
                    <div class="empty-state" style="margin-top: 16px;">
                        <i class="fi fi-rr-users-alt"></i>
                        <h3>No teams found</h3>
                        <p>Try a different search, or create the first team for your game.</p>
                    </div>
                }
                else
                {
                    <div style="overflow-x: auto; margin-top: 14px;">
                        <table class="community-table">
                            <thead>
                                <tr>
                                    <th style="width: 52px;"></th>
                                    <th>Team</th>
                                    <th style="width: 130px;">Status</th>
                                    <th style="width: 120px;">Players</th>
                                    <th style="width: 120px;">Subs</th>
                                    <th style="width: 120px;">Coaches</th>
                                    <th style="width: 220px;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var t in Model.Teams)
                                {
                                    <tr>
                                        <td>
                                            @if (!string.IsNullOrWhiteSpace(t.LogoUrl))
                                            {
                                                <img src="@t.LogoUrl" alt="Logo" style="width: 36px; height: 36px; border-radius: 10px; object-fit: cover;" />
                                            }
                                            else
                                            {
                                                <div style="width: 36px; height: 36px; border-radius: 10px; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.12);"></div>
                                            }
                                        </td>
                                        <td>
                                            <a asp-action="TeamDetails" asp-route-id="@t.Id" style="color: white; text-decoration: none; font-weight: 700;">
                                                @t.FullName <span style="opacity: .7;">(@t.Tag)</span>
                                            </a>
                                        </td>
                                        <td>
                                            @if (t.IsApproved)
                                            {
                                                <span class="community-badge community-badge-success">Approved</span>
                                            }
                                            else
                                            {
                                                <span class="community-badge community-badge-warning">Pending</span>
                                            }
                                        </td>
                                        <td>@t.PlayersCount / 5</td>
                                        <td>@t.SubstitutesCount</td>
                                        <td>@t.CoachesCount</td>
                                        <td>
                                            <div class="community-actions">
                                                <a asp-action="TeamDetails" asp-route-id="@t.Id" class="btn-action btn-action-view">
                                                    <i class="fi fi-rr-eye"></i>
                                                    <span>View</span>
                                                </a>
                                                @if (User.Identity?.IsAuthenticated == true && !t.IsMember)
                                                {
                                                    <form asp-action="RequestJoin" method="post" class="d-inline">
                                                        <input type="hidden" name="teamId" value="@t.Id" />
                                                        <button type="submit" class="btn-action btn-action-publish">
                                                            <i class="fi fi-rr-paper-plane"></i>
                                                            <span>Request</span>
                                                        </button>
                                                    </form>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <div class="community-card">
            <div class="community-card-body">
                <div class="community-actions" style="justify-content: space-between;">
                    <h3 style="margin: 0;">Users</h3>
                    <span class="community-badge">@Model.Users.Count results</span>
                </div>

                @if (Model.Users.Count == 0)
                {
                    <p style="margin-top: 14px; color: rgba(255,255,255,0.6);">Search to find users.</p>
                }
                else
                {
                    <div style="overflow-x: auto; margin-top: 14px;">
                        <table class="community-table">
                            <thead>
                                <tr>
                                    <th>Username</th>
                                    <th>Full name</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var u in Model.Users)
                                {
                                    <tr>
                                        <td style="font-weight: 700;">@u.Username</td>
                                        <td style="opacity: .85;">@u.FullName</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
