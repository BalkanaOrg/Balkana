@model string
@{
    ViewData["Title"] = ViewData["Title"] ?? "Tournament results preview";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <div class="card bg-dark text-white">
                <div class="card-header bg-gradient d-flex justify-content-between align-items-center flex-wrap gap-2"
                     style="background: linear-gradient(135deg, #1e40af, #dc2626);">
                    <h3 class="card-title mb-0">
                        <i class="fas fa-eye me-2"></i>
                        Plain-text preview (Discord embed summary)
                    </h3>
                    <a asp-action="DiscordTournamentResults" class="btn btn-outline-light btn-sm">Back to post</a>
                </div>
                <div class="card-body">
                    <pre class="bg-black text-light p-3 rounded border border-secondary overflow-auto" style="white-space: pre-wrap; max-height: 70vh;">@Model</pre>
                </div>
            </div>
        </div>
    </div>
</div>
