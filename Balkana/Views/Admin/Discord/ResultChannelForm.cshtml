@model Balkana.Data.Models.DiscordGameResultChannel
@{
    var isEdit = Model.Id > 0;
    ViewData["Title"] = isEdit ? "Edit Discord result channel" : "Add Discord result channel";
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card bg-dark text-white">
                <div class="card-header bg-gradient" style="background: linear-gradient(135deg, #1e40af, #dc2626);">
                    <h3 class="card-title mb-0">
                        <i class="fas fa-edit me-2"></i>
                        @ViewData["Title"]
                    </h3>
                </div>
                <div class="card-body">
                    <form asp-controller="Admin" asp-action="@(isEdit ? "DiscordResultChannelEdit" : "DiscordResultChannelCreate")" asp-route-id="@(isEdit ? Model.Id : null)" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="All" class="text-danger mb-3" role="alert"></div>
                        @if (isEdit)
                        {
                            <input type="hidden" asp-for="Id" />
                        }

                        <div class="mb-3">
                            <label asp-for="GameId" class="form-label">Game</label>
                            <select asp-for="GameId" asp-items="ViewBag.GamesSelect" class="form-select bg-dark text-white border-secondary">
                                <option value="">— Select game —</option>
                            </select>
                            <span asp-validation-for="GameId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="DiscordChannelId" class="form-label">Discord channel ID (snowflake)</label>
                            <input asp-for="DiscordChannelId" class="form-control bg-dark text-white border-secondary" autocomplete="off" />
                            <span asp-validation-for="DiscordChannelId" class="text-danger"></span>
                            <div class="form-text text-muted">Numeric ID from Discord (developer mode → copy channel ID).</div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="DisplayLabel" class="form-label">Display label (optional)</label>
                            <input asp-for="DisplayLabel" class="form-control bg-dark text-white border-secondary" />
                        </div>

                        <div class="mb-4 form-check">
                            <input asp-for="IsActive" class="form-check-input" />
                            <label asp-for="IsActive" class="form-check-label">Active</label>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Save</button>
                            <a asp-action="DiscordResultChannels" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
