@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "Post tournament results to Discord";
    var previewActionUrl = Url.Action("DiscordTournamentResultsPreview", "Admin")!;
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card bg-dark text-white">
                <div class="card-header bg-gradient" style="background: linear-gradient(135deg, #1e40af, #dc2626);">
                    <h3 class="card-title mb-0">
                        <i class="fas fa-trophy me-2"></i>
                        Post tournament results to Discord
                    </h3>
                </div>
                <div class="card-body">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success">@TempData["Success"]</div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger">@TempData["Error"]</div>
                    }

                    <p class="text-muted">
                        Sends rich embeds to the channel configured for this tournament’s game, unless you override the channel ID below.
                    </p>

                    <form asp-action="DiscordTournamentResults" method="post" class="mb-4">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label for="tournamentId" class="form-label">Tournament</label>
                            <select name="tournamentId" id="tournamentId" class="form-select bg-dark text-white border-secondary" required>
                                <option value="">— Select tournament —</option>
                                @if (ViewBag.TournamentSelect is SelectList tl)
                                {
                                    foreach (var item in tl)
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="channelIdOverride" class="form-label">Channel ID override (optional)</label>
                            <input type="text" name="channelIdOverride" id="channelIdOverride" class="form-control bg-dark text-white border-secondary" autocomplete="off" />
                            <div class="form-text text-muted">Leave empty to use the mapped channel for the tournament’s game.</div>
                        </div>
                        <div class="d-flex flex-wrap gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-paper-plane me-1"></i> Post to Discord
                            </button>
                            <button type="button" class="btn btn-outline-info" id="btnPreview">
                                <i class="fas fa-eye me-1"></i> Preview text
                            </button>
                        </div>
                    </form>

                    <p class="text-muted small mb-0">
                        Ensure <code class="text-info">BaseUrl</code> in configuration matches the public site used in embed links.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
(function () {
    var previewActionUrl = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(previewActionUrl));
    document.getElementById('btnPreview').addEventListener('click', function () {
        var id = document.getElementById('tournamentId').value;
        if (!id) { alert('Select a tournament first.'); return; }
        var base = previewActionUrl.replace(/\/$/, '');
        window.location.href = base + '/' + encodeURIComponent(id);
    });
})();
</script>
