@model Balkana.Models.Tournaments.GenerateTournamentCodesViewModel

@{
    ViewData["Title"] = "Generate Tournament Codes";
    Layout = "_Layout";
}

<link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />

<div class="admin-container">
    <div class="admin-header" style="text-align: left;">
        <h1 style="justify-content: flex-start;">Generate Tournament Codes</h1>
        <p class="admin-subtitle">Tournament: <strong style="color: #e5e7eb;">@Model.TournamentName</strong></p>
    </div>

    <div class="admin-layout-split">
        <div>
            <form asp-action="GenerateTournamentCodes" method="post">
                <input type="hidden" asp-for="RiotTournamentId" />
                <input type="hidden" asp-for="TournamentName" />

                <div asp-validation-summary="ModelOnly" class="alert alert-error admin-validation-summary"></div>

                <div class="admin-form-field">
                    <label asp-for="Count" class="admin-form-label"></label>
                    <input asp-for="Count" class="admin-form-input" type="number" min="1" max="100" />
                    <span asp-validation-for="Count" class="admin-field-error"></span>
                    <span class="admin-form-hint">Between 1 and 100 codes per request.</span>
                </div>

                <div class="admin-form-field">
                    <label asp-for="Description" class="admin-form-label"></label>
                    <input asp-for="Description" class="admin-form-input" placeholder="e.g., Match 1 – Group Stage" />
                    <span asp-validation-for="Description" class="admin-field-error"></span>
                </div>

                <div class="admin-form-field">
                    <label asp-for="SeriesId" class="admin-form-label"></label>
                    <select asp-for="SeriesId" asp-items="Model.AvailableSeries" class="admin-form-select">
                        <option value="">-- None (Optional) --</option>
                    </select>
                    <span asp-validation-for="SeriesId" class="admin-field-error"></span>
                </div>

                <div class="admin-form-field">
                    <label asp-for="TeamSize" class="admin-form-label"></label>
                    <select asp-for="TeamSize" class="admin-form-select">
                        <option value="1">1v1</option>
                        <option value="2">2v2</option>
                        <option value="3">3v3</option>
                        <option value="4">4v4</option>
                        <option value="5" selected>5v5</option>
                    </select>
                    <span asp-validation-for="TeamSize" class="admin-field-error"></span>
                </div>

                <div class="admin-form-field">
                    <label asp-for="TeamAId" class="admin-form-label"></label>
                    <select asp-for="TeamAId" asp-items="Model.AvailableTeams" class="admin-form-select">
                        <option value="">-- None (Optional) --</option>
                    </select>
                    <span asp-validation-for="TeamAId" class="admin-field-error"></span>
                </div>

                <div class="admin-form-field">
                    <label asp-for="TeamBId" class="admin-form-label"></label>
                    <select asp-for="TeamBId" asp-items="Model.AvailableTeams" class="admin-form-select">
                        <option value="">-- None (Optional) --</option>
                    </select>
                    <span asp-validation-for="TeamBId" class="admin-field-error"></span>
                </div>

                <div class="admin-form-field">
                    <label asp-for="MapType" class="admin-form-label"></label>
                    <select asp-for="MapType" asp-items="Model.MapTypes" class="admin-form-select"></select>
                    <span asp-validation-for="MapType" class="admin-field-error"></span>
                </div>

                <div class="admin-form-field">
                    <label asp-for="PickType" class="admin-form-label"></label>
                    <select asp-for="PickType" asp-items="Model.PickTypes" class="admin-form-select"></select>
                    <span asp-validation-for="PickType" class="admin-field-error"></span>
                </div>

                <div class="admin-form-field">
                    <label asp-for="SpectatorType" class="admin-form-label"></label>
                    <select asp-for="SpectatorType" asp-items="Model.SpectatorTypes" class="admin-form-select"></select>
                    <span asp-validation-for="SpectatorType" class="admin-field-error"></span>
                </div>

                <div class="admin-form-field">
                    <label asp-for="Metadata" class="admin-form-label"></label>
                    <textarea asp-for="Metadata" class="admin-form-textarea" rows="3" placeholder="Leave empty if you do not need stored metadata"></textarea>
                    <span asp-validation-for="Metadata" class="admin-field-error"></span>
                    <span class="admin-form-hint">Optional. Sent to Riot only when non-empty.</span>
                </div>

                <div class="admin-inline-actions" style="margin-top: 1rem;">
                    <button type="submit" class="btn-link" style="border: none; cursor: pointer;">
                        <i class="fas fa-code"></i> Generate Codes
                    </button>
                    <a asp-action="RiotTournamentDetails" asp-route-id="@Model.RiotTournamentId" class="btn-unlink" style="text-decoration: none;">
                        <i class="fas fa-times"></i> Cancel
                    </a>
                </div>
            </form>
        </div>

        <aside class="admin-side-panel">
            <h5>After you generate codes</h5>
            <ol>
                <li>Share the code with players.</li>
                <li>They create a custom game with the code.</li>
                <li>Check results from this admin area.</li>
                <li>Import replays / match history as usual.</li>
            </ol>
            <hr style="border-color: rgba(75, 85, 99, 0.5); margin: 1rem 0;" />
            <h5>Settings</h5>
            <ul>
                <li><strong>Map:</strong> Which map the lobby uses.</li>
                <li><strong>Pick type:</strong> Champion select mode.</li>
                <li><strong>Spectators:</strong> Who may spectate.</li>
            </ul>
        </aside>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
