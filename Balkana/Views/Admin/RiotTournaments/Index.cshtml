@model Balkana.Models.Tournaments.RiotTournamentListViewModel

@{
    ViewData["Title"] = "Riot Tournaments";
    Layout = "_Layout";
}

<link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />

<div class="admin-container">
    <div class="admin-toolbar">
        <div class="admin-header" style="margin-bottom: 0; text-align: left;">
            <h1 style="justify-content: flex-start;">Riot Tournament Management</h1>
            <p class="admin-subtitle">Create codes and track League of Legends tournament stubs linked to Balkana.</p>
        </div>
        <div class="admin-toolbar-actions">
            <a asp-action="RiotPendingMatches" class="btn-unlink" style="text-decoration: none;">
                <i class="fas fa-inbox"></i> Pending Matches
            </a>
            <a asp-action="CreateRiotTournament" class="btn-link">
                <i class="fas fa-plus"></i> Create New Tournament
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            <i class="fas fa-check-circle"></i>
            @TempData["SuccessMessage"]
        </div>
    }

    @if (Model.Tournaments.Any())
    {
        <div class="users-table-container">
            <table class="users-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Region</th>
                        <th>Riot Tournament ID</th>
                        <th>Provider ID</th>
                        <th>Linked Tournament</th>
                        <th>Codes</th>
                        <th>Created</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var tournament in Model.Tournaments)
                    {
                        <tr>
                            <td>@tournament.Id</td>
                            <td><strong>@tournament.Name</strong></td>
                            <td><span class="admin-tag admin-tag-info">@tournament.Region</span></td>
                            <td>@tournament.RiotTournamentId</td>
                            <td>@tournament.ProviderId</td>
                            <td>
                                @if (tournament.TournamentId.HasValue)
                                {
                                    <span class="admin-tag admin-tag-success">@tournament.TournamentName</span>
                                }
                                else
                                {
                                    <span class="admin-tag admin-tag-muted">Not linked</span>
                                }
                            </td>
                            <td>
                                <span class="admin-tag admin-tag-info">@tournament.TotalCodes total</span>
                                <span class="admin-tag admin-tag-success">@tournament.UsedCodes used</span>
                                <span class="admin-tag admin-tag-warn">@tournament.UnusedCodes unused</span>
                            </td>
                            <td>@tournament.CreatedAt.ToString("yyyy-MM-dd")</td>
                            <td class="actions">
                                <div class="admin-inline-actions">
                                    <a asp-action="RiotTournamentDetails" asp-route-id="@tournament.Id" class="btn-update-role" style="text-decoration: none;">
                                        <i class="fas fa-eye"></i> Details
                                    </a>
                                    <a asp-action="GenerateTournamentCodes" asp-route-id="@tournament.Id" class="btn-link" style="padding: 0.35rem 0.65rem; font-size: 0.85rem;">
                                        <i class="fas fa-code"></i> Codes
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="admin-info-banner">
            <i class="fas fa-info-circle"></i>
            No Riot tournaments found. Create one to get started.
        </div>
    }

    <div class="admin-doc-block">
        <h4>What is the Riot Tournament API?</h4>
        <p>
            The Riot Tournament API lets you register League of Legends tournaments and generate tournament codes. Players use those codes for custom games; you can import match data via the Match History Importer.
        </p>
        <ul>
            <li><strong>Create tournament:</strong> Register with Riot and store the stub locally.</li>
            <li><strong>Generate codes:</strong> Issue codes for specific series or matches.</li>
            <li><strong>Import matches:</strong> Pull games played with those codes into Balkana.</li>
        </ul>
    </div>
</div>

@section Scripts {
    <script>
        setTimeout(function () {
            document.querySelectorAll('.alert.alert-success').forEach(function (el) {
                el.style.transition = 'opacity 0.4s ease';
                el.style.opacity = '0';
                setTimeout(function () { el.remove(); }, 400);
            });
        }, 5000);
    </script>
}
