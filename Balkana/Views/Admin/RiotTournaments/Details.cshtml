@model Balkana.Models.Tournaments.RiotTournamentDetailsViewModel

@{
    ViewData["Title"] = "Tournament Details - " + Model.Name;
    Layout = "_Layout";
}

<link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />

<div class="admin-container">
    @Html.AntiForgeryToken()

    <div class="admin-toolbar">
        <div class="admin-header" style="margin-bottom: 0; text-align: left;">
            <h1 style="justify-content: flex-start;">@Model.Name</h1>
            <p class="admin-subtitle">Riot tournament ID: @Model.RiotTournamentId</p>
        </div>
        <div class="admin-toolbar-actions">
            <a asp-action="GenerateTournamentCodes" asp-route-id="@Model.Id" class="btn-link">
                <i class="fas fa-code"></i> Generate Codes
            </a>
            <a asp-action="RiotTournaments" class="btn-unlink" style="text-decoration: none;">
                <i class="fas fa-arrow-left"></i> Back
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            <i class="fas fa-check-circle"></i>
            @TempData["SuccessMessage"]
        </div>
    }

    <div class="admin-stat-grid">
        <div class="admin-stat-card">
            <h5>Region</h5>
            <div class="admin-stat-value">@Model.Region</div>
        </div>
        <div class="admin-stat-card">
            <h5>Provider ID</h5>
            <div class="admin-stat-value">@Model.ProviderId</div>
        </div>
        <div class="admin-stat-card">
            <h5>Total codes</h5>
            <div class="admin-stat-value">@Model.TournamentCodes.Count</div>
        </div>
        <div class="admin-stat-card">
            <h5>Created</h5>
            <p class="admin-stat-sub">@Model.CreatedAt.ToString("yyyy-MM-dd")</p>
            <p class="admin-stat-sub">@Model.CreatedAt.ToString("HH:mm:ss") UTC</p>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.TournamentName))
    {
        <div class="admin-info-banner">
            <i class="fas fa-link"></i>
            Linked internal tournament: <strong>@Model.TournamentName</strong>
        </div>
    }

    <h2 class="section-title" style="color: #e5e7eb; font-size: 1.25rem; margin-bottom: 1rem;">Tournament codes</h2>

    @if (Model.TournamentCodes.Any())
    {
        <div class="users-table-container">
            <table class="users-table">
                <thead>
                    <tr>
                        <th>Code</th>
                        <th>Description</th>
                        <th>Series</th>
                        <th>Teams</th>
                        <th>Settings</th>
                        <th>Status</th>
                        <th>Match</th>
                        <th>Created</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var code in Model.TournamentCodes)
                    {
                        <tr class="@(code.IsUsed ? "row-used" : null)">
                            <td>
                                <span class="admin-code-inline tournament-code" data-code="@(code.Code)">@(code.Code)</span>
                                <button type="button" class="btn-update-role copy-btn" data-code="@(code.Code)" title="Copy" style="margin-left: 0.35rem;">
                                    <i class="fas fa-copy"></i>
                                </button>
                            </td>
                            <td>@(code.Description ?? "—")</td>
                            <td>@(code.SeriesName ?? "—")</td>
                            <td>
                                @if (code.TeamAId.HasValue || code.TeamBId.HasValue)
                                {
                                    <span>@(code.TeamAName ?? "?") vs @(code.TeamBName ?? "?")</span>
                                }
                                else
                                {
                                    <span class="admin-tag admin-tag-muted">Any teams</span>
                                }
                            </td>
                            <td>
                                <span class="admin-tag admin-tag-muted">@(code.MapType ?? "—")</span>
                                <span class="admin-tag admin-tag-muted">@(code.PickType ?? "—")</span>
                                <span class="admin-tag admin-tag-muted">@(code.TeamSize)v@(code.TeamSize)</span>
                            </td>
                            <td>
                                @if (code.IsUsed)
                                {
                                    <span class="admin-tag admin-tag-success">Used</span>
                                }
                                else
                                {
                                    <span class="admin-tag admin-tag-warn">Unused</span>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(code.MatchId))
                                {
                                    <div class="admin-inline-actions">
                                        <a asp-action="RiotMatchDetails" asp-route-matchId="@(code.MatchId)" class="btn-update-role" style="text-decoration: none;" target="_blank" rel="noopener">
                                            <i class="fas fa-external-link-alt"></i> Riot
                                        </a>
                                        @if (code.MatchDbId.HasValue)
                                        {
                                            <a asp-controller="Match" asp-action="Details" asp-route-id="@(code.MatchDbId)" class="btn-unlink" style="text-decoration: none;">
                                                Internal
                                            </a>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span style="color: #6b7280;">—</span>
                                }
                            </td>
                            <td>@code.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                @if (!code.IsUsed)
                                {
                                    <button type="button" class="btn-link check-code-btn" data-code="@(code.Code)" style="padding: 0.35rem 0.65rem; font-size: 0.85rem; border: none; cursor: pointer;">
                                        <i class="fas fa-sync"></i> Check
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="admin-info-banner">
            <i class="fas fa-info-circle"></i>
            No tournament codes yet. Use Generate Codes to create some.
        </div>
    }
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.copy-btn').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var code = this.getAttribute('data-code');
                navigator.clipboard.writeText(code).then(() => {
                    var icon = this.querySelector('i');
                    icon.classList.remove('fa-copy');
                    icon.classList.add('fa-check');
                    setTimeout(() => {
                        icon.classList.remove('fa-check');
                        icon.classList.add('fa-copy');
                    }, 2000);
                });
            });
        });

        document.querySelectorAll('.check-code-btn').forEach(function (btn) {
            btn.addEventListener('click', async function () {
                var code = this.getAttribute('data-code');
                var icon = this.querySelector('i');
                var tokenEl = document.querySelector('input[name="__RequestVerificationToken"]');
                var token = tokenEl ? tokenEl.value : '';

                this.disabled = true;
                icon.classList.add('fa-spin');

                try {
                    var response = await fetch('@Url.Action("CheckTournamentCode")', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': token
                        },
                        body: JSON.stringify({ code: code })
                    });

                    var contentType = response.headers.get('content-type');
                    if (!contentType || !contentType.includes('application/json')) {
                        throw new Error('Server returned an unexpected response');
                    }
                    var result = await response.json();

                    if (result.success) {
                        alert('Match found! Refreshing page...');
                        location.reload();
                    } else {
                        alert(result.message);
                    }
                } catch (error) {
                    alert('Error checking code: ' + error.message);
                } finally {
                    this.disabled = false;
                    icon.classList.remove('fa-spin');
                }
            });
        });

        setTimeout(function () {
            document.querySelectorAll('.alert.alert-success').forEach(function (el) {
                el.style.transition = 'opacity 0.4s ease';
                el.style.opacity = '0';
                setTimeout(function () { el.remove(); }, 400);
            });
        }, 5000);
    </script>
}
