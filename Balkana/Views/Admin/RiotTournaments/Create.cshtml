@model Balkana.Models.Tournaments.CreateRiotTournamentViewModel

@{
    ViewData["Title"] = "Create Riot Tournament";
    Layout = "_Layout";
}

<link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />

<div class="admin-container">
    <div class="admin-header" style="text-align: left;">
        <h1 style="justify-content: flex-start;">Create Riot Tournament</h1>
        <p class="admin-subtitle">Register a tournament with the Riot Tournament API.</p>
    </div>

    <div class="admin-layout-split">
        <div>
            <form asp-action="CreateRiotTournament" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-error admin-validation-summary"></div>

                <div class="admin-form-field">
                    <label asp-for="Name" class="admin-form-label"></label>
                    <input asp-for="Name" class="admin-form-input" placeholder="e.g., Spring Championship 2026" />
                    <span asp-validation-for="Name" class="admin-field-error"></span>
                </div>

                <div class="admin-form-field">
                    <label asp-for="Region" class="admin-form-label"></label>
                    <select asp-for="Region" asp-items="Model.AvailableRegions" class="admin-form-select">
                        <option value="">-- Select Region --</option>
                    </select>
                    <span asp-validation-for="Region" class="admin-field-error"></span>
                    <span class="admin-form-hint">League of Legends server region for this tournament.</span>
                </div>

                <div class="admin-form-field">
                    <label asp-for="TournamentId" class="admin-form-label"></label>
                    <select asp-for="TournamentId" asp-items="Model.InternalTournaments" class="admin-form-select">
                        <option value="">-- None (Optional) --</option>
                    </select>
                    <span asp-validation-for="TournamentId" class="admin-field-error"></span>
                    <span class="admin-form-hint">Optionally link to an internal Balkana tournament.</span>
                </div>

                <input type="hidden" asp-for="ProviderId" />

                <div class="admin-inline-actions" style="margin-top: 1rem;">
                    <button type="submit" class="btn-link" style="border: none; cursor: pointer;">
                        <i class="fas fa-save"></i> Create Tournament
                    </button>
                    <a asp-action="RiotTournaments" class="btn-unlink" style="text-decoration: none;">
                        <i class="fas fa-times"></i> Cancel
                    </a>
                </div>
            </form>
        </div>

        <aside class="admin-side-panel">
            <h5>What happens next</h5>
            <ul>
                <li>Registers a provider with Riot when needed.</li>
                <li>Creates a Riot tournament ID and stores it locally.</li>
                <li>You can then generate tournament codes for matches.</li>
            </ul>
        </aside>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
