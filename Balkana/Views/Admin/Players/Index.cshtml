@using Balkana.Data.Infrastructure
@model Balkana.Models.Admin.PlayersListViewModel
@{
    ViewData["Title"] = "Players and Game Profiles";
}

<h2 class="mb-4 text-white">Players &amp; Game Profiles</h2>

<table class="table table-bordered align-middle text-white">
    <thead class="table-dark">
        <tr>
            <th>Nickname</th>
            <th>Full Name</th>
            <th>FACEIT</th>
            <th>RIOT</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var player in Model.Players)
        {
            var faceitRows = player.ProfileRows.Where(r => GameProfileProviderExtensions.IsFaceitProvider(r.Provider)).ToList();
            var riotRows = player.ProfileRows.Where(r => GameProfileProviderExtensions.IsRiotProvider(r.Provider)).ToList();
            <tr>
                <td>@player.Nickname</td>
                <td>@player.FullName</td>

                <td>
                    @if (faceitRows.Any())
                    {
                        @foreach (var r in faceitRows)
                        {
                            var label = !string.IsNullOrEmpty(r.DisplayName) ? r.DisplayName : r.UuidShort;
                            <div><span class="badge bg-success me-1">@label</span></div>
                        }
                    }
                    <a asp-controller="Admin" asp-action="AddGameProfile" asp-route-playerId="@player.PlayerId" class="btn btn-sm btn-outline-primary mt-1">Add</a>
                </td>

                <td>
                    @if (riotRows.Any())
                    {
                        @foreach (var r in riotRows)
                        {
                            var label = !string.IsNullOrEmpty(r.DisplayName) ? r.DisplayName : r.UuidShort;
                            <div><span class="badge bg-success me-1">@label</span></div>
                        }
                    }
                    <a asp-action="AddGameProfile" asp-route-playerId="@player.PlayerId" class="btn btn-sm btn-outline-primary mt-1">Add</a>
                </td>
            </tr>
        }
    </tbody>
</table>
