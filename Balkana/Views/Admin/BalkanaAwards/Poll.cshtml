@{
    ViewData["Title"] = "Balkana Awards - Community Poll";
    var year = (int)(ViewBag.Year ?? DateTime.UtcNow.Year);
}

<div class="container py-4">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-4">
        <div>
            <h1 class="h3 mb-1">Community poll</h1>
            <div class="text-muted">Configure voting window and eligibility for Balkana Awards @year.</div>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-outline-light" asp-controller="Admin" asp-action="BalkanaAwards">Back to hub</a>
            <a class="btn btn-outline-light" asp-controller="Admin" asp-action="BalkanaAwardsManual" asp-route-year="@year">Manual award giving</a>
        </div>
    </div>

    <div class="alert alert-info">
        This page will manage:\n
        <ul class="mb-0">
            <li>Voting open/close times</li>
            <li>Eligible player lists for: Entry Fragger, AWPer, IGL</li>
            <li>Visibility/state for community-voted categories</li>
        </ul>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="card bg-dark border-secondary">
        <div class="card-body d-flex align-items-center justify-content-between flex-wrap gap-3">
            <div>
                <div class="fw-bold">Finalize Player of the Year top10</div>
                <div class="text-muted">Computes CS/LoL top10 from match stats in the selected year and snapshots them into `BalkanaAwardResults`.</div>
            </div>
            <form method="post" asp-controller="Admin" asp-action="BalkanaAwardsFinalizePoty" asp-route-year="@year">
                @Html.AntiForgeryToken()
                <button class="btn btn-primary" type="submit">Finalize POTY @year</button>
            </form>
        </div>
    </div>
</div>

